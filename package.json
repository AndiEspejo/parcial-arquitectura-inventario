{
  "name": "warehouse-inventory-api",
  "version": "1.0.0",
  "description": "RESTful inventory API for warehouse product management — Parcial Práctico Arquitectura de Software",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "forceExit": true,
    "detectOpenHandles": true,
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "commonjs"
        }
      }
    }
  }
}
